<PenguinsFrontendProject version="1.0" created="2025-05-27">
    
    <!-- PROJECT OVERVIEW -->
    <ProjectOverview>
        <name>Pittsburgh Penguins xG Visualizer</name>
        <description>Vue.js frontend for hockey analytics visualization</description>
        <status>Phase 2 In Progress - Core visualization complete</status>
        <tech_stack>
            <framework>Vue 3 with TypeScript</framework>
            <build_tool>Vite</build_tool>
            <styling>CSS (Tailwind ready)</styling>
            <state>Pinia</state>
            <routing>Vue Router</routing>
        </tech_stack>
    </ProjectOverview>

    <!-- COMPLETED COMPONENTS -->
    <CompletedComponents>
        <Component path="src/components/RinkVisualization.vue" status="complete">
            <description>Main interactive rink with xG predictions</description>
            <features>
                <feature>Interactive shot placement</feature>
                <feature>Real-time xG calculation</feature>
                <feature>Shot type and modifier controls</feature>
                <feature>Heat map visualization</feature>
                <feature>Two modes: Interactive and NHL Data</feature>
            </features>
            <dependencies>
                <dependency>axios</dependency>
                <dependency>NHLRink.vue</dependency>
                <dependency>rinkDimensions.ts</dependency>
            </dependencies>
        </Component>
        
        <Component path="src/components/NHLRink.vue" status="complete">
            <description>Accurate NHL rink SVG component</description>
            <features>
                <feature>Official NHL dimensions (200ft x 85ft)</feature>
                <feature>Proper zone markings and circles</feature>
                <feature>Shot marker visualization</feature>
                <feature>Click event handling</feature>
            </features>
        </Component>
        
        <Component path="src/views/RinkView.vue" status="complete">
            <description>Container view for rink visualization</description>
        </Component>
        
        <Component path="src/views/AnalyticsView.vue" status="placeholder">
            <description>Future analytics dashboard</description>
            <planned_features>
                <feature>Player impact scores</feature>
                <feature>Line chemistry analysis</feature>
                <feature>Game momentum tracker</feature>
                <feature>Shot pattern analysis</feature>
            </planned_features>
        </Component>
    </CompletedComponents>

    <!-- SERVICES AND UTILITIES -->
    <Services>
        <Service path="src/services/penguinsAPI.ts" status="complete">
            <description>API client for backend communication</description>
            <endpoints>
                <endpoint method="POST" path="/predict/expected-goals">Single shot prediction</endpoint>
                <endpoint method="POST" path="/predict/batch">Batch predictions</endpoint>
                <endpoint method="GET" path="/model/info">Model metadata</endpoint>
                <endpoint method="GET" path="/health">Health check</endpoint>
            </endpoints>
        </Service>
        
        <Service path="src/services/nhlDataService.ts" status="scaffold">
            <description>NHL data integration service</description>
            <planned_integrations>
                <integration>NHL official API</integration>
                <integration>MoneyPuck data</integration>
                <integration>Live game feeds</integration>
            </planned_integrations>
        </Service>
    </Services>

    <!-- TYPE DEFINITIONS -->
    <TypeDefinitions>
        <TypeFile path="src/types/rinkDimensions.ts" status="complete">
            <exports>
                <export>NHLRinkDimensions interface</export>
                <export>NHL_RINK constants</export>
                <export>nhlToSvg() converter</export>
                <export>svgToNhl() converter</export>
                <export>calculateShotMetrics() function</export>
            </exports>
        </TypeFile>
    </TypeDefinitions>

    <!-- ROUTING -->
    <Routes>
        <Route path="/" component="HomeView" status="default" />
        <Route path="/rink" component="RinkView" status="complete" />
        <Route path="/analytics" component="AnalyticsView" status="placeholder" />
    </Routes>

